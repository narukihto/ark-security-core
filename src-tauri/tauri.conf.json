{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "distDir": "../src",
    "devPath": "../src",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "ArkSecurityCore",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false
      }
    },
    "bundle": {
      "active": true,
      "targets": ["msi", "nsis"],
      "identifier": "com.ark.security.core",
      "icon": [
        "icons/icon.ico"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; object-src 'none';"
    },
    "windows": [
      {
        "title": "Ark Security Core — Architectural Sovereign",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ]
  }
}
